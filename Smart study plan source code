import streamlit as st
import pandas as pd
from datetime import datetime, timedelta

st.set_page_config(page_title="Smart Study Planner", layout="centered")

st.title("📚 Smart Study Planner")
st.write("Generate your study plan based on subjects, syllabus size and exam date")

st.subheader("Enter Your Subjects")

# Number of subjects
num_subjects = st.number_input("Number of Subjects", min_value=1, max_value=10, step=1)

subjects = []
chapters = []

for i in range(num_subjects):
    col1, col2 = st.columns(2)
    
    with col1:
        subject = st.text_input(f"Subject {i+1} Name")
    
    with col2:
        chapter = st.number_input(f"Number of Chapters {i+1}", min_value=1, step=1, key=i)
    
    if subject:
        subjects.append(subject)
        chapters.append(chapter)

st.subheader("Select Exam Date")

exam_date = st.date_input("Exam Date")

if st.button("Generate Study Plan"):

    if len(subjects) == 0:
        st.error("Please enter at least one subject")
    
    else:
        today = datetime.today().date()
        days_left = (exam_date - today).days

        if days_left <= 0:
            st.error("Exam date must be in the future")
        
        else:
            st.success(f"Days Left: {days_left} days")

            total_chapters = sum(chapters)

            st.write(f"Total Chapters: {total_chapters}")

            study_plan = []

            current_day = today
            subject_index = 0
            chapter_count = [0] * len(subjects)

            while sum(chapter_count) < total_chapters:
                
                if chapter_count[subject_index] < chapters[subject_index]:
                    
                    study_plan.append({
                        "Date": current_day,
                        "Subject": subjects[subject_index],
                        "Chapter": f"Chapter {chapter_count[subject_index] + 1}"
                    })

                    chapter_count[subject_index] += 1
                    current_day += timedelta(days=1)

                subject_index = (subject_index + 1) % len(subjects)

            df = pd.DataFrame(study_plan)

            st.subheader("📅 Your Study Plan")

            st.dataframe(df)

            st.subheader("📊 Study Progress Overview")

            progress_data = {
                "Subject": subjects,
                "Chapters": chapters
            }

            progress_df = pd.DataFrame(progress_data)

            st.bar_chart(progress_df.set_index("Subject"))

            st.success("Study Plan Generated Successfully!")
